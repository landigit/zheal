{
  "name": "zheal-dev",
  "version": "1.0.0",
  "description": "TypeScript Node.js Express Backend for zheal Nutrient Tracker",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "build": "pnpm build:backend && pnpm build:frontend",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "express": "^4.22.2",
    "node-appwrite": "^26.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "svelte": "^5.56.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}